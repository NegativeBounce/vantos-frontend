# Vite inlines VITE_* at build time. Set these in DigitalOcean App Platform (BUILD_TIME).
# Public, URL-restricted Mapbox client token (it is public after build — that's expected):
VITE_MAPBOX_TOKEN=
# Backend base URL. Leave EMPTY for topology A (same app: /api routed to the backend).
VITE_API_BASE_URL=
